FROM node:18-alpine

WORKDIR /monorepo

# Install development dependencies
RUN apk add --no-cache git

# Copy workspace config + package.json files
COPY package.json package-lock.json ./
COPY packages/shared/package.json packages/shared/
COPY frontend/package.json frontend/

# Install all dependencies including dev dependencies
RUN npm ci

# Create non-root user
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nextjs -u 1001 && \
    chown -R nextjs:nodejs /monorepo

USER nextjs

# The actual code will be mounted as a volume
# Vite dev server will run on port 3333 with hot reload
EXPOSE 3333

# Command will be specified in docker-compose
